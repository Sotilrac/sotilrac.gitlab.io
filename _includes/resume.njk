{% from "icon.njk" import icon %}
<div class="col-content" style="position:relative">
    <button class="print-btn no-print" onclick="window.print()">Print / Save PDF</button>
    <div class="row d-none d-print-flex">
        <div class="col">
            <h1>{{ resume.first_name }} {{ resume.last_name }}</h1>
        </div>
        <div class="col contact">
            <ul class="contact-print">
                <li id="phone"><span class="icon">{{ icon("fa-phone") }}</span><span id="phoneContent"></span></li>
                <li id="email"><span class="icon">{{ icon("fa-envelope") }}</span><span id="emailContent"></span></li>
                {% for link in resume.links %}
                  {% if link.icon == "fa-globe" %}
                <li><span class="icon">{{ icon(link.icon) }}</span><span><a href="{{ link.url }}">{{ link.title }}</a></span></li>
                  {% endif %}
                {% endfor %}
            </ul>
        </div>
    </div>
    <section class="no-page-break">
        <h2>Summary</h2>
        <img src="{{ resume.picture }}" alt="{{ resume.first_name }} {{ resume.last_name }}" class="float-left pic"/>
        {% for line in resume.summary %}
        <p class="lead summary">{{ line }}</p>
        {% endfor %}
    </section>
    <section class="no-page-break">
        <h2>Skills</h2>
        <div class="row">
            <div class="col col-skill">
                <h3 class="sub_section_header">Leadership:</h3>
                <ul class="programming">
                    {% for skill in resume.skills.soft %}
                    <li>{{ skill }}</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col col-skill">
                <h3 class="sub_section_header">Programming:</h3>
                <ul class="programming">
                    {% for skill in resume.skills.programming %}
                    <li>{{ skill }}</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col col-skill">
                <h3 class="sub_section_header">Engineering Tools:</h3>
                <ul class="tools">
                    {% for skill in resume.skills.tools %}
                    <li>{{ skill }}</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col col-skill">
                <h3 class="sub_section_header">Fluent in:</h3>
                <ul class="languages">
                    {% for skill in resume.skills.languages %}
                    <li>{{ skill }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </section>
    <section>
        <h2>Experience</h2>
        {% for exp in resume.experience %}
        <div class="row job">
            <div class="col-aside date_col">
                <span class="dates">{{ exp.start_date }} -</span>
                <span class="dates">{{ exp.end_date }}</span>
            </div>
            <div class="col col-job">
                <h3>
                    <span class="company">{{ exp.company }}:</span>
                    <span class="title">{{ exp.title }}</span>
                    <span class="location">({{ exp.location }})</span>
                </h3>
                <ul>
                    {% for line in exp.description %}
                    <li>{{ line.item }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        {% endfor %}
    </section>
    <section class="no-page-break">
        <h2>Education</h2>
        <div class="education-grid">
        {% for ed in resume.education %}
            <div class="education-entry">
                <div class="row">
                    <div class="col-aside date_col">
                        <span class="dates">{{ ed.start_date }} - {{ ed.end_date }}</span>
                    </div>
                    <div class="col col-job educ_col">
                        <h3 class="institution">{{ ed.institution }}</h3>
                        <span class="dates-print">{{ ed.start_date }} - {{ ed.end_date }}</span>
                        <ul class="degrees">
                            {% for degree in ed.degree %}
                            <li>{{ degree.item }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
        {% endfor %}
        </div>
    </section>
    <section class="no-page-break">
        <h2>Personal Projects</h2>
        <p class="no-print" style="color:var(--slate);font-size:0.9em">See the <a href="/blog/">blog</a> for latest projects.</p>
        {% for project in resume.projects %}
        <div class="row">
            <div class="col-aside date_col">
                <p class="dates">{{ project.start_date }}</p>
            </div>
            <div class="col col-job proj_col">
                <h3>
                    <span class="project_name">{{ project.name }}</span>
                </h3>
                <ul class="project_description">
                    {% for line in project.description %}
                    <li>{{ line }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        {% endfor %}
    </section>
</div>
<div style="margin-bottom:3em"></div>
