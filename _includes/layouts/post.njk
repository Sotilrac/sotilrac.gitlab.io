---
layout: layouts/base.njk
---
<article class="post col-content" itemscope itemtype="http://schema.org/BlogPosting">
    <header class="post-header">
        <h1 class="post-title" itemprop="name headline">{{ title }}</h1>
        <p class="post-meta">
            <time datetime="{{ date | dateFormat('iso') }}" itemprop="datePublished">
                {{ date | dateFormat('isodate') }}
            </time>
            {% if tags | length %}
            <span class="post-tags">{% for tag in tags %}{% if tag != "posts" %}<a class="post-tag" href="/tags/?tag={{ tag }}">{{ tag }}</a>{% endif %}{% endfor %}</span>
            {% endif %}
        </p>
    </header>

    <div class="post-content" itemprop="articleBody">
        {{ content | safe }}
    </div>

    {% set slug = page.fileSlug | postSlug %}
    {% set postComments = comments[slug] %}
    {% if postComments %}
    <section class="post-comments">
        <h2>Comments from the original blog</h2>
        {% for c in postComments %}
        <div class="blog-comment">
            <div class="blog-comment-meta">
                <strong class="blog-comment-author">{{ c.author }}</strong>
                <time class="blog-comment-date">{{ c.date }}</time>
            </div>
            <div class="blog-comment-text">{{ c.text | nl2br | safe }}</div>
        </div>
        {% endfor %}
    </section>
    {% endif %}

    {% set nav = collections.publicPosts | postNavigation(page.url) %}
    {% if nav.prev or nav.next %}
    <nav class="post-nav">
        {% if nav.prev %}<a class="post-nav-prev" href="{{ nav.prev.url }}">&larr; {{ nav.prev.data.title }}</a>{% endif %}
        {% if nav.next %}<a class="post-nav-next" href="{{ nav.next.url }}">{{ nav.next.data.title }} &rarr;</a>{% endif %}
    </nav>
    {% endif %}
</article>
