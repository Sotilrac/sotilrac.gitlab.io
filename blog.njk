---
layout: layouts/page.njk
title: Blog
permalink: /blog/
---

<div class="posts col-content">

  <p class="archive-blurb">Musings, projects, and learnings by a robotics engineer.</p>

  <ul class="cat-legend">
    <li><span class="cat-dot" data-cat="info"></span>Info</li>
    <li><span class="cat-dot" data-cat="news"></span>News</li>
    <li><span class="cat-dot" data-cat="projects"></span>Projects</li>
    <li><span class="cat-dot" data-cat="robotics"></span>Robotics</li>
    <li><span class="cat-dot" data-cat="software"></span>Software</li>
    <li><span class="cat-dot" data-cat="til"></span>TIL</li>
    <li><span class="cat-dot" data-cat="tools"></span>Tools</li>
  </ul>

  <div class="archive-grid">
    {% for year in [2026, 2023, 2022, 2021, 2019] %}
    <section class="archive-year">
      <h3>{{ year }}</h3>
      <ul class="post-list">
        {% for post in collections.publicPosts %}
          {% if post.date.getFullYear() == year %}
          <li>
            <span class="post-meta">{{ post.date | dateFormat("isodate") }}</span>
            {% if post.data.categories %}<span class="cat-dot" data-cat="{{ post.data.categories[0] | lower }}"></span>{% endif %}
            <a class="post-link" href="{{ post.url }}">{{ post.data.title }}</a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
    </section>
    {% endfor %}
  </div>

  <h2 class="page-heading archive-heading">Carlitos' Contraptions Archive</h2>
  <p class="archive-blurb">An earlier life of tinkering with robots, and questionable soldering.
  Dug out from the sands of WordPress at the old <em>carlitoscontraptions.com</em> domain.</p>

  <div class="archive-grid">
    {% for year in [2013, 2012, 2011, 2010, 2009, 2008, 2007, 2006] %}
    <section class="archive-year">
      <h3>{{ year }}</h3>
      <ul class="post-list">
        {% for post in collections.publicPosts %}
          {% if post.date.getFullYear() == year %}
          <li>
            <span class="post-meta">{{ post.date | dateFormat("isodate") }}</span>
            {% if post.data.categories %}<span class="cat-dot" data-cat="{{ post.data.categories[0] | lower }}"></span>{% endif %}
            <a class="post-link" href="{{ post.url }}">{{ post.data.title }}</a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
    </section>
    {% endfor %}
  </div>

  {% if collections.publicPosts.length == 0 %}
  <p>Blog posts are being migrated. Check back soon.</p>
  {% endif %}
</div>

<script>
(function () {
  var legend = document.querySelector(".cat-legend");
  if (!legend) return;
  var items = legend.querySelectorAll("li");
  var posts = document.querySelectorAll(".post-list li");
  var active = null;

  function filterCat(cat) {
    if (!cat || active === cat) {
      active = null;
      legend.classList.remove("filtering");
      items.forEach(function (i) { i.classList.remove("active"); });
      posts.forEach(function (p) { p.style.display = ""; });
      history.replaceState(null, "", "/blog/");
    } else {
      active = cat;
      legend.classList.add("filtering");
      items.forEach(function (i) { i.classList.remove("active"); });
      items.forEach(function (li) {
        var d = li.querySelector(".cat-dot");
        if (d && d.getAttribute("data-cat") === cat) li.classList.add("active");
      });
      posts.forEach(function (p) {
        var pDot = p.querySelector(".cat-dot");
        var pCat = pDot ? pDot.getAttribute("data-cat") : null;
        p.style.display = pCat === cat ? "" : "none";
      });
      history.replaceState(null, "", "/blog/?cat=" + encodeURIComponent(cat));
    }
  }

  items.forEach(function (li) {
    li.addEventListener("click", function () {
      var dot = li.querySelector(".cat-dot");
      var cat = dot ? dot.getAttribute("data-cat") : null;
      filterCat(cat);
    });
  });

  var param = new URLSearchParams(window.location.search).get("cat");
  if (param) filterCat(param.toLowerCase());
})();
</script>
